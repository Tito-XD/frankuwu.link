---
import { SITE } from "@/siteConfig";
---

<div class="identity-card">
  <p class="identity-card__eyebrow">User ID</p>
  <h1 class="identity-card__name">{SITE.name}</h1>
  <div class="identity-card__rule"></div>

  <div class="identity-card__meta">
    <div>
      <span class="identity-card__label">Access Note</span>
      <p>{SITE.bio}</p>
    </div>

    <div>
      <span class="identity-card__label">Current Focus</span>
      <p>
        Portfolio-first landing page for artworks, process fragments, and future
        visual experiments.
      </p>
    </div>

    <div class="identity-card__access">
      <span class="identity-card__label">Password</span>
      <div class="identity-card__mask" aria-hidden="true">
        <div class="identity-card__mask-bar"></div>
        <span class="identity-card__lock">O</span>
      </div>
      <p class="identity-card__hint">
        Direct portfolio images can slot in later without changing the overall
        frame language.
      </p>
    </div>
  </div>
</div>
