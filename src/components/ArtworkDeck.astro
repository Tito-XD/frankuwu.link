---
const artworkSlots = [
  {
    status: "PRIMARY",
    eyebrow: "Artwork Archive // 01",
    title: "Hero artwork slot",
    description:
      "Reserve this wide card for the first full illustration, poster crop, or a stitched multi-panel composition once assets are ready.",
  },
  {
    status: "QUEUE",
    eyebrow: "Artwork Archive // 02",
    title: "Process detail panel",
    description:
      "Useful for sketches, texture studies, or a tighter crop that supports the lead piece without turning the homepage into a full gallery.",
  },
  {
    status: "PATH",
    eyebrow: "Asset Route",
    title: "Reserved import path",
    description:
      "Keep future source files here. Once artwork lands in the folder, these placeholder cards can switch over to real imports and tuned compositions.",
  },
];
---

<section
  class="artwork-section liquid-island liquid-island--archive"
  id="artwork"
  data-liquid-island
>
  <div class="artwork-heading">
    <p class="section-kicker">Artwork Archive</p>
    <h2>Portfolio space first, noise second.</h2>
    <p>
      The front page still stays image-led. Once you add source files, we can
      decide whether the fold should land as one hero piece, a diptych, or a
      denser editorial collage.
    </p>
    <span class="asset-path">src/assets/artworks/</span>
  </div>

  <div class="artwork-grid">
    {
      artworkSlots.map((slot, index) => (
        <article class:list={["art-card", index === 0 && "art-card--feature"]}>
          <div class="art-card__visual">
            <span class="art-card__badge">{slot.status}</span>
          </div>
          <div class="art-card__content">
            <p class="section-kicker">{slot.eyebrow}</p>
            <h3>{slot.title}</h3>
            <p>{slot.description}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>
