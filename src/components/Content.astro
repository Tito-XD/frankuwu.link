---
import { SITE } from "@/siteConfig";

import ArtworkDeck from "@/components/ArtworkDeck.astro";
import CustomLink from "@/components/CustomLink.astro";
import IconLink from "@/components/IconLink.astro";
import Introduction from "@/components/Introduction.astro";
import SocialSignals from "@/components/SocialSignals.astro";

const diagnostics = [
  "STR: READY",
  "WEP: STICK",
  "DEC: CLEAN",
  "DATASET: LOCAL",
];
---

<section class="portfolio-shell">
  <div class="ambient-orb ambient-orb--one" aria-hidden="true"></div>
  <div class="ambient-orb ambient-orb--two" aria-hidden="true"></div>
  <div class="ambient-orb ambient-orb--three" aria-hidden="true"></div>
  <div class="hud-frame hud-frame--outer" aria-hidden="true"></div>
  <div class="hud-frame hud-frame--inner" aria-hidden="true"></div>

  <div class="shell-topbar">
    <div>
      <div class="status-cluster" aria-hidden="true">
        <span class="status-pill">SCAN</span>
        <span class="status-pill">LINK</span>
        <span class="status-pill">WEB</span>
        <span class="status-dot"></span>
      </div>
      <p class="system-note">TERMINAL MODEL: LOCAL PROFILE NODE</p>
    </div>

    <div class="status-clock" aria-label="interface status">
      <span class="status-clock__stamp">NODE-01</span>
      <span class="status-clock__mark" aria-hidden="true"></span>
    </div>
  </div>

  <section class="hero-panel liquid-island liquid-island--hero" data-liquid-island>
    <div class="hero-panel__halo hero-panel__halo--large" aria-hidden="true"></div>
    <div class="hero-panel__halo hero-panel__halo--small" aria-hidden="true"></div>

    <div class="hero-grid">
      <div class="scan-module">
        <div class="scan-module__frame">
          <div class="scan-module__portrait">
            <img
              src="/Avatar.jpg"
              alt={SITE.name}
              width="320"
              height="320"
              loading="eager"
              draggable="false"
              class="scan-module__image"
              onerror="this.onerror=null;this.src='/avatar-frank-tiger.svg';"
            />
          </div>
        </div>
        <p class="scan-module__title">Facial Archive</p>
        <p class="scan-module__sub">
          Primary portrait slot for the homepage shell. The scan frame stays
          clean, so future image swaps will not collide with decorative copy.
        </p>
      </div>

      <div class="hero-sidebar">
        <Introduction />

        {
          SITE.iconLinks.length ? (
            <ul class="social-grid">
              {SITE.iconLinks.map((link) => (
                <IconLink url={link.url} icon={link.icon} />
              ))}
            </ul>
          ) : null
        }

        {
          SITE.customLinks.length ? (
            <div class="terminal-links">
              <p class="section-kicker">Open Channels</p>
              <ul class="command-grid">
                {SITE.customLinks.map((link) => (
                  <CustomLink url={link.url}>{link.title}</CustomLink>
                ))}
              </ul>
            </div>
          ) : null
        }
      </div>
    </div>

    <div class="hero-panel__fingerprint" aria-hidden="true"></div>
  </section>

  <SocialSignals />

  <ArtworkDeck />

  <div class="diagnostic-bar" aria-label="diagnostic notes">
    {diagnostics.map((item) => <span>{item}</span>)}
  </div>
</section>

<script>
  const islands = document.querySelectorAll("[data-liquid-island]");

  for (const island of islands) {
    let frame = null;
    let currentX = 50;
    let currentY = 50;
    let currentTiltX = 0;
    let currentTiltY = 0;
    let targetX = 50;
    let targetY = 50;
    let targetTiltX = 0;
    let targetTiltY = 0;

    const animate = () => {
      currentX += (targetX - currentX) * 0.1;
      currentY += (targetY - currentY) * 0.1;
      currentTiltX += (targetTiltX - currentTiltX) * 0.08;
      currentTiltY += (targetTiltY - currentTiltY) * 0.08;

      island.style.setProperty("--glow-x", `${currentX}%`);
      island.style.setProperty("--glow-y", `${currentY}%`);
      island.style.setProperty("--tilt-x", `${currentTiltX}deg`);
      island.style.setProperty("--tilt-y", `${currentTiltY}deg`);

      const moving =
        Math.abs(targetX - currentX) > 0.02 ||
        Math.abs(targetY - currentY) > 0.02 ||
        Math.abs(targetTiltX - currentTiltX) > 0.02 ||
        Math.abs(targetTiltY - currentTiltY) > 0.02;

      frame = moving ? requestAnimationFrame(animate) : null;
    };

    const start = () => {
      if (frame === null) frame = requestAnimationFrame(animate);
    };

    island.addEventListener("pointermove", (event) => {
      const rect = island.getBoundingClientRect();
      const ratioX = (event.clientX - rect.left) / rect.width;
      const ratioY = (event.clientY - rect.top) / rect.height;

      targetX = ratioX * 100;
      targetY = ratioY * 100;
      targetTiltX = (ratioY - 0.5) * -3.8;
      targetTiltY = (ratioX - 0.5) * 5.2;
      start();
    });

    island.addEventListener("pointerleave", () => {
      targetX = 50;
      targetY = 50;
      targetTiltX = 0;
      targetTiltY = 0;
      start();
    });
  }
</script>
