---
import { SITE } from "@/siteConfig";

const xProfileUrl = SITE.iconLinks.find((link) => link.icon === "x")?.url ?? "https://x.com/FrankUwu71426";

const socialFeeds = [
  {
    platform: "X",
    handle: "@FrankUwu71426",
    url: xProfileUrl,
    summary: "Furry art, Splatoon energy, and small playful updates in one running feed.",
    links: [
      {
        label: "Open profile",
        url: xProfileUrl,
      },
    ],
  },
  {
    platform: "Xiaohongshu",
    handle: "Frank uwu",
    url: "https://www.xiaohongshu.com/user/profile/623d64d600000000100067bb",
    summary: "Design check-ins and recent illustration posts collected from the linked account.",
    links: SITE.customLinks.map((link) => ({
      label: link.title,
      url: link.url,
    })),
  },
];
---

<section class="profile-stack" aria-label="Linked profiles">
  {
    socialFeeds.map((feed) => (
      <article class="profile-card">
        <div class="profile-card__header">
          <div>
            <p class="section-kicker">{feed.platform}</p>
            <h2 class="profile-card__title">{feed.handle}</h2>
          </div>
          <a href={feed.url} class="profile-card__cta" target="_blank" rel="noreferrer">
            Open
          </a>
        </div>

        <p class="profile-card__summary">{feed.summary}</p>

        <div class="profile-card__links">
          {feed.links.map((item) => (
            <a href={item.url} class="profile-chip" target="_blank" rel="noreferrer">
              <span class="profile-chip__label">{item.label}</span>
              <span class="profile-chip__suffix">&gt;&gt;</span>
            </a>
          ))}
        </div>
      </article>
    ))
  }
</section>
