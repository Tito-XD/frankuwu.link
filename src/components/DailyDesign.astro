---
import { Image } from "astro:assets";

const dailyImages = import.meta.glob("../assets/daily-30/*.{png,jpg,jpeg,webp}", {
  eager: true,
  import: "default",
});

const dailyEntries = Object.entries(dailyImages)
  .map(([path, image]) => {
    const match = path.match(/(\d+)/);
    const day = match ? Number(match[1]) : 0;

    return {
      day,
      image,
      label: `Day ${String(day).padStart(2, "0")}`,
    };
  })
  .filter((entry) => entry.day > 0)
  .sort((a, b) => b.day - a.day);

const latest = dailyEntries[0];
const rest = dailyEntries.slice(1);
---

{
  latest ? (
    <section class="daily-design">
      <div class="daily-design__header">
        <p class="section-kicker">Daily Design</p>
        <h2>{latest.label}</h2>
      </div>

      {/* Hero: latest image displayed fully, no crop */}
      <div class="daily-hero">
        <Image
          src={latest.image}
          alt={`${latest.label} design check-in`}
          width={900}
          height={1200}
          loading="eager"
          class="daily-hero__image"
        />
        <div class="daily-hero__badge">{latest.label}</div>
      </div>

      {/* Thumbnail strip: all previous days */}
      {rest.length > 0 && (
        <div class="daily-strip__scroll">
          <div class="daily-strip">
            {rest.map((entry) => (
              <div class="daily-thumb">
                <Image
                  src={entry.image}
                  alt={`${entry.label} design check-in`}
                  width={400}
                  height={534}
                  loading="lazy"
                  class="daily-thumb__image"
                />
                <span class="daily-thumb__label">{entry.label}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>
  ) : null
}
